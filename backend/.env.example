# Cloudflare R2 credentials (required for r2 storage mode)
S3_ENDPOINT=
S3_KEY_ID=
S3_KEY_SECRET=
S3_BUCKET=vitavision

# Storage mode: auto | r2 | local
# auto = uses R2 if credentials are present, otherwise local
STORAGE_MODE=auto

# Optional: public base URL for R2 objects (e.g. https://pub-xxx.r2.dev)
R2_PUBLIC_BASE_URL=

# CORS: comma-separated list of allowed origins
# Example: http://localhost:5173,https://vitavision.example.com
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# API key for all /api/v1/* endpoints (X-API-Key header).
# Leave empty to disable authentication (dev/local mode only).
API_KEY=
