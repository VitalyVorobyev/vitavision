{
  "name": "vitcv",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "INCLUDE_DRAFTS=true bun run content:build && bun run atlas:layout && tsc -b && vite build",
