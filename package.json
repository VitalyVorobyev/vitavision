    "sources:fetch-repo": "bun run scripts/sources-fetch-repo.ts",
    "vault:build": "bun run scripts/atlas-vault-build.ts",
    "postbuild": "bun run scripts/postbuild.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
